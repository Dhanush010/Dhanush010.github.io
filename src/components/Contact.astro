---
import { siteConfig } from "../config";
---

<section id="contact" class="section-container border-t text-center" style="border-color: var(--border);">
  <h2 class="text-2xl md:text-3xl font-semibold text-white mb-4">
    {siteConfig.contact.heading}
  </h2>

  <p class="text-base max-w-xl mx-auto mb-8 leading-relaxed" style="color: var(--text-secondary);">
    {siteConfig.contact.description}
  </p>

  <div class="flex flex-wrap justify-center gap-4 mb-6">
    <a
      href={`mailto:${siteConfig.social.email}`}
      class="btn-ghost"
    >
      {siteConfig.social.email}
    </a>
    <a
      href={siteConfig.social.linkedin}
      target="_blank"
      rel="noopener noreferrer"
      class="btn-ghost"
    >
      LinkedIn
      <svg class="external-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7V17" />
      </svg>
    </a>
    <a
      href={siteConfig.social.github}
      target="_blank"
      rel="noopener noreferrer"
      class="btn-ghost"
    >
      GitHub
      <svg class="external-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7V17" />
      </svg>
    </a>
  </div>

  <p class="text-sm" style="color: var(--text-secondary);">
    {siteConfig.contact.location}
  </p>
</section>
