---
import { siteConfig } from "../config";
---

<section id="experience" class="section-container border-t" style="border-color: var(--border);">
  <h2 class="section-heading">Experience</h2>

  <div class="relative pl-8">
    <!-- Timeline line -->
    <div
      class="absolute left-[7px] top-2 bottom-2 w-px"
      style="background-color: var(--border);"
    ></div>

    <div class="space-y-12">
      {
        siteConfig.experience.map((exp) => (
          <div class="relative">
            <!-- Timeline dot -->
            <div
              class="absolute -left-8 top-1.5 w-3.5 h-3.5 rounded-full border-2"
              style="background-color: var(--bg-primary); border-color: var(--accent);"
            ></div>

            <p class="font-mono text-sm mb-2" style="color: var(--text-secondary);">
              {exp.dateRange}
            </p>

            <h3 class="text-lg font-semibold text-white mb-0.5">
              {exp.title}
            </h3>

            <p class="text-base mb-4" style="color: var(--accent);">
              {exp.company}
            </p>

            <ul class="space-y-2 mb-4">
              {exp.bullets.map((bullet) => (
                <li class="flex items-start gap-3 text-sm md:text-base" style="color: var(--text-secondary);">
                  <span class="mt-2 w-1 h-1 rounded-full flex-shrink-0" style="background-color: var(--text-secondary);"></span>
                  {bullet}
                </li>
              ))}
            </ul>

            <div class="flex flex-wrap gap-2">
              {exp.tags.map((tag) => (
                <span class="tag-pill">{tag}</span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
