---
import { siteConfig } from "../config";
---

<section id="hero" class="relative min-h-screen flex flex-col">
  <div class="page-container flex-1 flex flex-col justify-center pt-20 pb-24">
    <p class="font-mono text-sm mb-6" style="color: var(--text-secondary);">
      {siteConfig.availability}
    </p>

    <p class="text-lg mb-2" style="color: var(--text-secondary);">
      Hi, I'm
    </p>

    <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight text-white mb-4 leading-tight">
      {siteConfig.name}
    </h1>

    <p class="text-xl md:text-2xl font-medium mb-2" style="color: var(--accent);">
      {siteConfig.title}
    </p>

    <p class="text-base mb-8" style="color: var(--text-secondary);">
      {siteConfig.tagline}
    </p>

    <div class="flex flex-wrap gap-3 mb-10">
      <a href="#projects" class="btn-primary">
        View Projects →
      </a>
      <a
        href={siteConfig.social.github}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-ghost"
      >
        GitHub
        <svg class="external-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7V17" />
        </svg>
      </a>
      <a
        href={siteConfig.social.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-ghost"
      >
        LinkedIn
        <svg class="external-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7V17" />
        </svg>
      </a>
    </div>

    <p class="text-sm flex flex-wrap items-center gap-y-1" style="color: var(--text-secondary);">
      {
        siteConfig.achievements.map((item, i) => (
          <>
            {i > 0 && (
              <span class="achievement-sep" aria-hidden="true">·</span>
            )}
            <span>{item}</span>
          </>
        ))
      }
    </p>
  </div>

  <a
    href="#about"
    aria-label="Scroll to about section"
    class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1 transition-opacity hover:opacity-80"
    style="color: var(--text-secondary);"
  >
    <svg
      class="w-5 h-5 animate-bounce-subtle"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
      stroke-width="1.5"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
    </svg>
  </a>
</section>

<style>
  .achievement-sep {
    color: #cbd5e1;
    margin: 0 0.75rem;
    opacity: 0.7;
  }

  @keyframes bounce-subtle {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(4px); }
  }

  .animate-bounce-subtle {
    animation: bounce-subtle 2s ease-in-out infinite;
  }
</style>
