---
import { siteConfig } from "../config";

const { heroCard } = siteConfig;
---

<section id="hero" class="hero-section relative">
  <div class="page-container">
    <div class="hero-grid w-full">
      <div>
        <p class="font-mono text-sm mb-6" style="color: var(--text-secondary);">
          {siteConfig.availability}
        </p>

        <p class="text-lg mb-2 hi-greeting">
          Hi, I'm
        </p>

        <h1 class="hero-name font-bold tracking-tight text-white mb-4 leading-tight">
          {siteConfig.name}
        </h1>

        <p class="hero-subtitle font-medium mb-2" style="color: var(--accent);">
          {siteConfig.title}
        </p>

        <p class="text-base mb-8" style="color: var(--text-secondary);">
          {siteConfig.tagline}
        </p>

        <div class="flex flex-wrap gap-3 mb-10">
          <a href="#projects" class="btn-primary">
            View Projects →
          </a>
          <a
            href={siteConfig.social.github}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-ghost"
          >
            GitHub
            <svg class="external-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7V17" />
            </svg>
          </a>
          <a
            href={siteConfig.social.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-ghost"
          >
            LinkedIn
            <svg class="external-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7V17" />
            </svg>
          </a>
        </div>

        <ul class="achievements-list text-sm" style="color: var(--text-secondary);">
          {
            siteConfig.achievements.map((item) => (
              <li>{item}</li>
            ))
          }
        </ul>
      </div>

      <aside class="hero-terminal hidden md:block" aria-hidden="true">
        <pre class="hero-terminal-pre font-mono text-sm leading-relaxed"><code><span class="json-brace">{'{'}</span>
  <span class="json-key">"role"</span>:     <span class="json-string">"{heroCard.role}"</span>,
  <span class="json-key">"location"</span>: <span class="json-string">"{heroCard.location}"</span>,
  <span class="json-key">"status"</span>:   <span class="json-string">"{heroCard.status}"</span>,
  <span class="json-key">"gsoc"</span>:     <span class="json-string">"{heroCard.gsoc}"</span>,
  <span class="json-key">"gpa"</span>:      <span class="json-string">"{heroCard.gpa}"</span>
<span class="json-brace">{'}'}</span></code></pre>
      </aside>
    </div>
  </div>

  <a
    href="#about"
    aria-label="Scroll to about section"
    class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1 transition-opacity hover:opacity-80"
    style="color: var(--text-secondary);"
  >
    <svg
      class="w-5 h-5 animate-bounce-subtle"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
      stroke-width="1.5"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
    </svg>
  </a>
</section>

<style>
  .hero-section {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 100vh;
  }

  .hero-grid {
    display: grid;
    align-items: center;
    gap: 2.5rem;
  }

  @media (min-width: 768px) {
    .hero-grid {
      grid-template-columns: 60% 40%;
      gap: 3rem;
    }
  }

  .hi-greeting {
    color: #94a3b8 !important;
  }

  .hero-name {
    font-size: clamp(1.8rem, 3.8vw, 3rem);
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.375rem);
    white-space: nowrap;
  }

  .hero-terminal {
    width: 100%;
    opacity: 0.55;
  }

  .hero-terminal-pre {
    width: 100%;
    margin: 0;
    padding: 1.25rem 1.5rem;
    border-radius: 0.75rem;
    border: 1px solid var(--border);
    background-color: rgba(26, 29, 39, 0.6);
    color: var(--text-secondary);
    white-space: pre;
    overflow: hidden;
  }

  .json-key {
    color: #94a3b8;
  }

  .json-string {
    color: #a5b4fc;
  }

  .json-brace {
    color: var(--text-secondary);
    opacity: 0.7;
  }

  .achievements-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .achievements-list li::before {
    content: "▸ ";
    color: #6366f1;
  }

  @keyframes bounce-subtle {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(4px); }
  }

  .animate-bounce-subtle {
    animation: bounce-subtle 2s ease-in-out infinite;
  }

  @media (max-width: 480px) {
    .hero-subtitle {
      white-space: normal;
    }
  }
</style>
