---
import { siteConfig } from "../config";
---

<section id="opensource" class="section-container border-t" style="border-color: var(--border);">
  <h2 class="section-heading">Open Source</h2>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {
      siteConfig.openSource.map((contrib) => (
        <div class="card card-accent-left">
          <div class="flex items-center gap-3 mb-4">
            <div
              class="w-9 h-9 rounded-lg flex items-center justify-center text-sm font-bold text-white flex-shrink-0"
              style={`background-color: ${contrib.iconColor};`}
            >
              {contrib.icon}
            </div>
            <div>
              <h3 class="font-semibold text-white">{contrib.org}</h3>
              <div class="flex items-center gap-2 text-sm">
                <span class="font-mono" style="color: var(--text-secondary);">
                  PR {contrib.prNumber}
                </span>
                <span
                  class="text-xs font-mono px-2 py-0.5 rounded"
                  style="background-color: var(--green-muted); color: var(--green);"
                >
                  Merged ✓
                </span>
              </div>
            </div>
          </div>

          <h4 class="text-base font-medium text-white mb-3">
            {contrib.prTitle}
          </h4>

          <p class="text-sm leading-relaxed mb-4" style="color: var(--text-secondary);">
            {contrib.description}
          </p>

          <div class="flex flex-wrap gap-2 mb-5">
            {contrib.tags.map((tag) => (
              <span class="tag-pill">{tag}</span>
            ))}
          </div>

          <a
            href={contrib.prLink}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-sm font-medium transition-colors"
            style="color: var(--accent);"
          >
            View PR
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7V17" />
            </svg>
          </a>
        </div>
      ))
    }
  </div>
</section>
