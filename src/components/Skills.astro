---
import { siteConfig } from "../config";

const icons: Record<string, string> = {
  code: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>`,
  server: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2"/></svg>`,
  cloud: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/></svg>`,
  chart: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>`,
  test: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
};

const mainCategories = siteConfig.skills.filter((s) => !s.fullWidth);
const testingCategory = siteConfig.skills.find((s) => s.fullWidth);
---

<section id="skills" class="section-container border-t" style="border-color: var(--border);">
  <h2 class="section-heading">Skills</h2>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
    {
      mainCategories.map((group) => (
        <div>
          <div class="flex items-center gap-2 mb-4" style="color: var(--accent);">
            <div set:html={icons[group.icon]} />
            <h3 class="text-sm font-semibold uppercase tracking-wider text-white">
              {group.category}
            </h3>
          </div>
          <ul class="space-y-1.5">
            {group.items.map((skill) => (
              <li class="text-sm" style="color: var(--text-secondary);">
                {skill}
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>

  {
    testingCategory && (
      <div class="mt-10 pt-8 border-t" style="border-color: var(--border);">
        <div class="flex items-center gap-2 mb-3" style="color: var(--accent);">
          <div set:html={icons[testingCategory.icon]} />
          <h3 class="text-sm font-semibold uppercase tracking-wider text-white">
            {testingCategory.category}
          </h3>
        </div>
        <p class="text-sm font-mono" style="color: var(--text-secondary);">
          {testingCategory.items.join(' · ')}
        </p>
      </div>
    )
  }
</section>
